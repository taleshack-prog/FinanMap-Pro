# FinanMap Pro — Variáveis de Ambiente
# Copie para .env e preencha os valores reais
# NUNCA commitar o .env no Git

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=gere-com-openssl-rand-hex-32

# ── CORS — adicione seu domínio de produção ───────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8081","https://finanmap.pro"]

# ── Supabase (Postgres + Realtime) ────────────────────────────────────────────
# Criar projeto em: https://supabase.com (free tier: queries <50ms)
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
DATABASE_URL=postgresql+asyncpg://postgres:password@db.xxxx.supabase.co:5432/postgres

# ── yFinance / Alpha Vantage ──────────────────────────────────────────────────
# yfinance: grátis, 5k calls/dia, latência <500ms
# Alpha Vantage premium (R$50/mês): dados IR/Dividendos BR
ALPHA_VANTAGE_KEY=sua-chave-alpha-vantage
YFINANCE_CACHE_TTL=300

# ── Anthropic (Claude) — IA Advisor ──────────────────────────────────────────
# Obter em: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-...
CLAUDE_MODEL=claude-sonnet-4-20250514

# ── Monte Carlo ───────────────────────────────────────────────────────────────
MONTE_CARLO_SIMS=10000
MONTE_CARLO_MU=0.12
MONTE_CARLO_SIGMA=0.18
RISK_FREE_RATE=0.105

# ── Redis (cache produção) ────────────────────────────────────────────────────
# Render.com: Redis grátis 25MB / Upstash: free tier
REDIS_URL=redis://localhost:6379
BINANCE_API_KEY=h2jLfl5ygkyT10OFj7K3ABeEv6Fps7YpDAMehRLDPZ3htCsPcDQdyWPKAOHmYRKc
BINANCE_API_SECRET=5d16B2hAHEvRfVZW9LszAvcfEjO8SV6XuG8bg8xLhd1XSvdB4jZnaoH5tLIgTHDz

